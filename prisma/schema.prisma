generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl se usa para migraciones (evita el pooler de Neon en prod).
  // En local apunta al mismo Docker; en prod apunta a la conexión directa de Neon.
  directUrl = env("DIRECT_URL")
}

// ─── Organización ─────────────────────────────────────────────────────────────
// Unidad raíz de multi-tenancy. Cada entidad de negocio tendrá organizationId.

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  owners         Owner[]
  projects       Project[]
  parcels        Parcel[]
  projectParcels ProjectParcel[]
  contracts      Contract[]
  parcelContacts ParcelContact[]

  @@map("organizations")
}

// ─── Propietario ───────────────────────────────────────────────────────────────
// Propietario de parcelas. Sigue el patrón multi-tenancy: organizationId siempre
// filtrado desde sesión JWT, nunca desde el cliente.

model Owner {
  id             String       @id @default(cuid())
  name           String
  nif            String
  address        String?
  phone          String?
  email          String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  contracts Contract[]

  @@map("owners")
}

// ─── Proyecto ─────────────────────────────────────────────────────────────────
// Proyecto de energía renovable. Estado controlado por enum para garantizar
// integridad a nivel de base de datos.
// geometry: GeoJSON Polygon/MultiPolygon como Json? — sin PostGIS por ahora.
// En la siguiente fase se sustituirá o complementará con geometría espacial real.

enum ProjectStatus {
  OPPORTUNITY     // Oportunidad
  IN_DEVELOPMENT  // En Desarrollo
  RTB             // Ready to Build
  IN_CONSTRUCTION // En Construcción
  IN_OPERATION    // En Operación

  @@map("project_status")
}

model Project {
  id               String        @id @default(cuid())
  name             String
  // Potencia total MW — derivada de la suma de technologies[].powerMW.
  // Puede ser null si ninguna tecnología tiene potencia definida.
  // Mantenida para compatibilidad con KML, tabla, detalle.
  powerMW          Float?
  // Array de {type: string, powerMW?: number} — validado en app layer con Zod.
  // Migración futura: tabla ProjectTechnology si se necesitan queries por tipo.
  technologies     Json?
  status           ProjectStatus @default(OPPORTUNITY)
  // Campos relacionales como texto libre. FK en fases futuras.
  connectionPoints String[]
  cluster          String?
  developer        String?
  spv              String?
  geometry         Json?
  organizationId   String
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  projectParcels ProjectParcel[]

  @@map("projects")
}

// ─── Parcela ──────────────────────────────────────────────────────────────────
// Parcela catastral. cadastralRef único por organización (no global):
//   @@unique([cadastralRef, organizationId]) — restricción compuesta en Prisma.
// geometry: GeoJSON Polygon/MultiPolygon como Json? — mismo patrón que Project.
// Preparada para: importación CSV, relaciones Project/Owner, PostGIS futuro.

model Parcel {
  id             String       @id @default(cuid())
  cadastralRef   String
  polygon        String
  parcelNumber   String
  surface        Float
  municipality   String?
  landUse        String?
  geometry       Json?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  projectParcels ProjectParcel[]
  contracts      Contract[]
  contacts       ParcelContact[]

  @@unique([cadastralRef, organizationId])
  @@map("parcels")
}

// ─── Relación Proyecto ↔ Parcela ──────────────────────────────────────────────
// Tabla intermedia M:N. organizationId denormalizado para simplificar queries
// multi-tenant sin JOINs extra. @@unique garantiza que cada parcela se asigna
// como máximo una vez por proyecto.

model ProjectParcel {
  id             String       @id @default(cuid())
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parcelId       String
  parcel         Parcel       @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  // Afección de la parcela en este proyecto concreto.
  affectation    String?
  // Notas de contratación en el contexto de este proyecto.
  // Separadas de Parcel.notes (que serían globales) para permitir notas distintas por proyecto.
  notes             String?
  // Estado operativo de negociación en este proyecto — independiente del estado legal del contrato.
  negotiationStatus NegotiationStatus @default(SEARCHING)
  organizationId    String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([projectId, parcelId])
  @@map("project_parcels")
}

// ─── Contrato ─────────────────────────────────────────────────────────────────
// Contrato de arrendamiento o compraventa sobre una parcela catastral.
// Vinculado a una parcela y un propietario de la misma organización.
// Enums en BD para integridad: ContractType, ContractStatus.
// Preparado para ampliar con: cláusulas, fases, anexos, expedientes.

enum ContractType {
  RENTAL
  PURCHASE

  @@map("contract_type")
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED

  @@map("contract_status")
}

enum NegotiationStatus {
  SEARCHING        // Buscando propietario / sin contacto
  NEGOTIATING      // En negociación activa
  ACCEPTED         // Acuerdo verbal alcanzado
  SIGNED           // Contrato firmado (ACTIVE)
  NOT_NEGOTIATING  // No quiere negociar
  COMPETITION      // Competencia — otro promotor
  DUPLICATE        // Duplicado — cubierto por otra parcela
  TERMINATED       // Proceso cerrado / abandonado

  @@map("negotiation_status")
}

model Contract {
  id             String         @id @default(cuid())
  type           ContractType
  status         ContractStatus @default(DRAFT)
  price          Float?
  signedAt       DateTime?
  parcelId       String
  parcel         Parcel         @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  ownerId        String
  owner          Owner          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("contracts")
}

// ─── Contacto de parcela ──────────────────────────────────────────────────────
// Persona de contacto/gestión asociada a una parcela. Semánticamente distinta
// del Owner (propietario catastral que firma contratos).
// Rol: texto libre + catálogo en app layer para no requerir migrations al añadir roles.
// Ejemplos de rol: API, Interlocutor familiar, Agricultor, Abogado / Gestor, Otro.

model ParcelContact {
  id             String       @id @default(cuid())
  name           String
  role           String
  phone          String?
  email          String?
  notes          String?
  parcelId       String
  parcel         Parcel       @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("parcel_contacts")
}

// ─── Usuario ──────────────────────────────────────────────────────────────────
// Pertenece a una organización. En fases futuras habrá roles (ADMIN, VIEWER…).

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  passwordHash   String
  name           String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("users")
}
