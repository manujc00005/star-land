generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl se usa para migraciones (evita el pooler de Neon en prod).
  // En local apunta al mismo Docker; en prod apunta a la conexión directa de Neon.
  directUrl = env("DIRECT_URL")
}

// ─── Organización ─────────────────────────────────────────────────────────────
// Unidad raíz de multi-tenancy. Cada entidad de negocio tendrá organizationId.

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  owners          Owner[]
  projects        Project[]
  parcels         Parcel[]
  projectParcels  ProjectParcel[]
  contracts       Contract[]
  parcelContacts  ParcelContact[]
  contractParcels ContractParcel[]

  @@map("organizations")
}

// ─── Propietario ───────────────────────────────────────────────────────────────
// Propietario de parcelas. Sigue el patrón multi-tenancy: organizationId siempre
// filtrado desde sesión JWT, nunca desde el cliente.

model Owner {
  id             String       @id @default(cuid())
  name           String
  nif            String
  address        String?
  phone          String?
  email          String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  contracts Contract[]

  @@map("owners")
}

// ─── Proyecto ─────────────────────────────────────────────────────────────────
// Proyecto de energía renovable. Estado controlado por enum para garantizar
// integridad a nivel de base de datos.
// geometry: GeoJSON Polygon/MultiPolygon como Json? — sin PostGIS por ahora.

enum ProjectStatus {
  OPPORTUNITY     // Oportunidad
  IN_DEVELOPMENT  // En Desarrollo
  RTB             // Ready to Build
  IN_CONSTRUCTION // En Construcción
  IN_OPERATION    // En Operación

  @@map("project_status")
}

model Project {
  id               String        @id @default(cuid())
  name             String
  powerMW          Float?
  technologies     Json?
  status           ProjectStatus @default(OPPORTUNITY)
  connectionPoints String[]
  cluster          String?
  developer        String?
  spv              String?
  geometry         Json?
  organizationId   String
  organization     Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  projectParcels ProjectParcel[]

  @@map("projects")
}

// ─── Parcela ──────────────────────────────────────────────────────────────────
// Parcela catastral. cadastralRef único por organización (no global).

model Parcel {
  id             String       @id @default(cuid())
  cadastralRef   String
  polygon        String
  parcelNumber   String
  surface        Float
  municipality   String?
  landUse        String?
  geometry       Json?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  projectParcels  ProjectParcel[]
  contracts       Contract[]
  contacts        ParcelContact[]
  contractParcels ContractParcel[]

  @@unique([cadastralRef, organizationId])
  @@map("parcels")
}

// ─── Relación Proyecto ↔ Parcela ──────────────────────────────────────────────
// Tabla intermedia M:N. organizationId denormalizado para simplificar queries.

model ProjectParcel {
  id                String            @id @default(cuid())
  projectId         String
  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parcelId          String
  parcel            Parcel            @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  affectation       String?
  notes             String?
  negotiationStatus NegotiationStatus @default(SEARCHING)
  organizationId    String
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt         DateTime          @default(now())

  @@unique([projectId, parcelId])
  @@map("project_parcels")
}

// ─── Contrato ─────────────────────────────────────────────────────────────────
// Contrato de arrendamiento o compraventa sobre una parcela catastral.
// parcelId es la parcela principal (backward compat).
// contractParcels permite vincular parcelas adicionales (M:N).

enum ContractType {
  RENTAL
  PURCHASE

  @@map("contract_type")
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  SIGNED_ADDENDUM  // Firmado con adendas activas

  @@map("contract_status")
}

enum NegotiationStatus {
  SEARCHING        // Buscando propietario / sin contacto
  NEGOTIATING      // En negociación activa
  ACCEPTED         // Acuerdo verbal alcanzado
  SIGNED           // Contrato firmado (ACTIVE)
  NOT_NEGOTIATING  // No quiere negociar
  COMPETITION      // Competencia — otro promotor
  DUPLICATE        // Duplicado — cubierto por otra parcela
  TERMINATED       // Proceso cerrado / abandonado

  @@map("negotiation_status")
}

model Contract {
  id             String         @id @default(cuid())
  type           ContractType
  status         ContractStatus @default(DRAFT)
  price          Float?
  signedAt       DateTime?
  nextStep       String?
  nextStepDate   DateTime?
  notes          String?
  parcelId       String
  parcel         Parcel         @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  ownerId        String
  owner          Owner          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  contractParcels ContractParcel[]

  @@map("contracts")
}

// ─── Relación Contrato ↔ Parcela (M:N) ───────────────────────────────────────
// Permite vincular múltiples parcelas a un contrato.

model ContractParcel {
  id             String       @id @default(cuid())
  contractId     String
  contract       Contract     @relation(fields: [contractId], references: [id], onDelete: Cascade)
  parcelId       String
  parcel         Parcel       @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([contractId, parcelId])
  @@map("contract_parcels")
}

// ─── Contacto de parcela ──────────────────────────────────────────────────────

model ParcelContact {
  id             String       @id @default(cuid())
  name           String
  role           String
  phone          String?
  email          String?
  notes          String?
  parcelId       String
  parcel         Parcel       @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("parcel_contacts")
}

// ─── Usuario ──────────────────────────────────────────────────────────────────

model User {
  id             String       @id @default(cuid())
  email          String       @unique
  passwordHash   String
  name           String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("users")
}
